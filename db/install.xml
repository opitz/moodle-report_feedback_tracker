<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="report/feedback_tracker/db" VERSION="20240513" COMMENT="XMLDB file for Moodle report/feedback_tracker"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="report_feedback_tracker" COMMENT="Storing additional information about course modules">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="gradeitem" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="the grade item id"/>
        <FIELD NAME="summative" TYPE="int" LENGTH="1" NOTNULL="false" DEFAULT="0" SEQUENCE="false" COMMENT="summative or not"/>
        <FIELD NAME="hidden" TYPE="int" LENGTH="1" NOTNULL="false" DEFAULT="0" SEQUENCE="false" COMMENT="hidden or not"/>
        <FIELD NAME="feedbackduedate" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="method" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="responsibility" TYPE="text" LENGTH="medium" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="generalfeedback" TYPE="text" LENGTH="medium" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="gfurl" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>