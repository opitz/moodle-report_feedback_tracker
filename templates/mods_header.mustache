{{!
    @template report_feedback_tracker/mods_header

    Template for displaying a header for modules listed in a course.

    Example context (json):
    {
        "viewasstudent": false
    }

}}

<div class="row pb-3 mb-3 text-muted border-bottom d-none d-md-flex">
    <div class="col-5"></div>
    <div class="col-7">
        <div class="row no-gutters">
        {{#viewasstudent}}
            <div class="col-4">{{#str}} due, report_feedback_tracker {{/str}}</div>
            <div class="col-4">{{#str}} header:feedbackdue, report_feedback_tracker {{/str}}</div>
            <div class="col text-right">{{#str}} header:mark, report_feedback_tracker {{/str}}</div>
        {{/viewasstudent}}
        {{^viewasstudent}}
            <div class="col-4">{{#str}} header:feedbackdue, report_feedback_tracker {{/str}}</div>
            <div class="col-4">{{#str}} header:submitted, report_feedback_tracker {{/str}}</div>
            <div class="col">{{#str}} header:marking, report_feedback_tracker {{/str}}</div>
        {{/viewasstudent}}
        </div>
    </div>
</div>
