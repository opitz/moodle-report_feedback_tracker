{{!
    @template report_feedback_tracker/adminwrapper

    Table wrapper template for displaying the feedback records to admins/teachers.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "assessment": "",
                "duedate": "",
                "feedbackduedate": "",
                "feedbacks": "",
                "method": "",
                "responsibility": "",
                "generalfeedback": "",
                "summative": "",
                "hidden": ""
            }
        ]
    }

}}
<div id="feedback_tracker_studentdd" data-value="{{courseid}}">{{{studentdd}}}</div>
<div id="feedbacktable">
    {{> report_feedback_tracker/admintable}}
</div>
<hr>
