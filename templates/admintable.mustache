{{!
    @template report_feedback_tracker/admintable

    Template for displaying the feedback records to admins/teachers.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "assessment": "",
                "duedate": "",
                "feedbackduedate": "",
                "feedbacks": "",
                "method": "",
                "responsibility": "",
                "generalfeedback": "",
                "summative": "",
                "hidden": ""
            }
        ]
    }

}}
<div class="full-width">
    <div class="table-responsive p-5">
        <table id="js-feedback-table" class="table">
            <thead class="small bg-light">
            <tr>
                <th scope="col" class="align-top" style="min-width: 300px; width: 300px;">{{#str}} header:assessment, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} header:duedate, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} header:feedbacks, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" data-toggle="tooltip" title="{{#str}} method:tooltip, report_feedback_tracker {{/str}}">{{#str}} header:method, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} header:contact, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} header:generalfeedback, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} header:cohortfeedback, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} header:assessmenttype, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
            </tr>
            <tr id="feedback-table-filterrow">
                <td>
                    <label for="filtertype" class="sr-only">{{#str}}filter:type, report_feedback_tracker{{/str}}</label>
                    <select id="filtertype" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:type, report_feedback_tracker{{/str}}</option>
                        {{#typeoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/typeoptions}}
                    </select>
                </td>
                <td>
                </td>
                <td>
                </td>
                <td>
                    <label for="filtermethod" class="sr-only">{{#str}}filter:method, report_feedback_tracker{{/str}}</label>
                    <select id="filtermethod" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:method, report_feedback_tracker{{/str}}</option>
                        {{#methodoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/methodoptions}}
                    </select>
                </td>
                <td>
                    <label for="filterresponsibility" class="sr-only">{{#str}}filter:contact, report_feedback_tracker{{/str}}</label>
                    <input id="filterresponsibility" type="text" class="form-control form-control-sm w-100 filterresponsibility-input" data-column="0" placeholder="{{#str}}filter:typeto, report_feedback_tracker{{/str}}">
                </td>
                <td>
                    <label for="filtergeneralfeedback" class="sr-only">{{#str}}filter:generalfeedback, report_feedback_tracker{{/str}}</label>
                    <input id="filtergeneralfeedback" type="text" class="form-control form-control-sm w-100 filtergeneralfeedback-input" data-column="0" placeholder="{{#str}}filter:typeto, report_feedback_tracker{{/str}}">
                </td>
                <td>
                </td>
                <td>
                    <label for="filtersummative" class="sr-only">{{#str}}filter:summative, report_feedback_tracker{{/str}}</label>
                    <select id="filtersummative" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:summative, report_feedback_tracker{{/str}}</option>
                        {{#assesstypeoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/assesstypeoptions}}
                    </select>
                </td>
            </tr>
            </thead>
            <tbody>
            {{#records}}
                <tr>
                    <td class="col-assessment" data-filter="{{module}}" data-filter-assessment="{{module}}">
                        <div class="small w-100">
                            {{{coursename}}}{{#academicyear}} ({{academicyear}}){{/academicyear}}
                        </div>
                        <div class="w-100 sort-this">
                            {{{moduletypeicon}}} {{{assessment}}}
                        </div>
                    </td>
                    <td class="col-duedate text-nowrap small">
                        <div class="sort-this hidden">{{duedateraw}}</div>
                        <div>{{duedate}}</div>
                    </td>
                    <td class="col-feedbacks">
                        <div class="sort-this hidden">{{feedbackduedateraw}}</div>
                        <div class="small w-100 text-nowrap">
                            {{{feedbackduedate}}}
                        </div>
                        <div class="w-100">
                            {{{feedbacks}}}
                        </div>
                    </td>
                    <td class="col-method" data-filter="{{method}}">
                        <div class="sort-this">{{{method}}}</div>
                    </td>
                    <td class="col-responsibility textsearchable">
                        <div class="sort-this">{{{responsibility}}}</div>
                    </td>
                    <td class="col-generalfeedback textsearchable">
                        <div class="sort-this">{{{generalfeedback}}}</div>
                    </td>
                    <td class="col-cohortfeedback textsearchable">
                        <div class="sort-this">{{{cohortfeedback}}}</div>
                    </td>
                    <td class="col-summative text-center" data-filter="{{assesstypelabel}}">
                        <div class="sort-this">{{{assesstypelabel}}}</div>
                    </td>
                </tr>
            {{/records}}
            </tbody>
        </table>
    </div>
</div>

{{#js}}
    require(['report_feedback_tracker/studentview'], function(studentdd) {
        studentdd.init();
    });
    require(['report_feedback_tracker/tablefilters'], function(tablefilters) {
        tablefilters.init();
    });
    require(['report_feedback_tracker/tablesort'], function(tablesort) {
        tablesort.init();
    });
{{/js}}
