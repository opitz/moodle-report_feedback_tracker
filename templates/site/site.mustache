{{!
    @template report_feedback_tracker/site

    Template for displaying the feedback records to users/students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}
<div id="behat-feedback-area">
    <div class="sub-title">{{#str}} title:site_subtext, report_feedback_tracker {{/str}}</div>
    <hr>

    <p class="sr-only">{{#str}} site:menuguide, report_feedback_tracker {{/str}}</p>
    {{#menus}}
        {{> report_feedback_tracker/menu }}
    {{/menus}}

    <div class="small">{{#str}} site:note, report_feedback_tracker {{/str}}</div>
    <hr>

    <h2 class="h4 mb-3">{{yearname}} {{termname}} {{#str}} courses {{/str}}</h2>
    <div id="courses-area">
        {{#courses}}
            {{> report_feedback_tracker/site/courses }}
        {{/courses}}
        {{^courses}}
            {{#str}}site:nocourses, report_feedback_tracker{{/str}}
        {{/courses}}
    </div>

    {{#executiontime}}
        <div class="grey">
            {{.}}
        </div>
    {{/executiontime}}
</div>
