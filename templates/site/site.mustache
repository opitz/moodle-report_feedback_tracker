{{!
    @template report_feedback_tracker/site/site

    Template for displaying the feedback records to non-learners.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}
<div>{{#str}} title:site_subtext, report_feedback_tracker {{/str}}</div>
<hr>

{{! Navigation. }}
<p class="sr-only">{{#str}} site:menuguide, report_feedback_tracker {{/str}}</p>
{{#userreporturl}}
    <div>
        <p>
            <i class="icon fa-solid fa-table-list"></i>
            <a href="{{.}}">{{#str}} userreport, report_feedback_tracker {{/str}}</a>
        </p>
    </div>
{{/userreporturl}}

{{#menus}}
    {{> report_feedback_tracker/menu }}
{{/menus}}
<div class="small">{{#str}} site:note, report_feedback_tracker {{/str}}</div>
<hr>
<h2 class="h4 mb-3">{{yearname}} {{termname}} {{#str}} courses {{/str}}</h2>

{{! Courses. }}
{{#courses}}
    {{> report_feedback_tracker/site/courses }}
{{/courses}}
{{^courses}}
    {{#str}}site:nocourses, report_feedback_tracker{{/str}}
{{/courses}}


{{#executiontime}}
    <div class="grey">
        {{.}}
    </div>
{{/executiontime}}

