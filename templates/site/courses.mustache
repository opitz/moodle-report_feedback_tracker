{{!
    @template report_feedback_tracker/site/courses

    Template for displaying the feedback records to teachers.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }
}}
<div class="pb-4">
    {{> report_feedback_tracker/course_header }}

    {{> report_feedback_tracker/mods_header }}

    {{#items}}
        {{> report_feedback_tracker/mod }}
    {{/items}}
</div>
