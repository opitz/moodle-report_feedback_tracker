<div class="module">
    <div class="row">
        {{! Mod details. }}
        <div class="col-12 col-md-5 my-1">
            <a href="{{{url}}}">
                {{#manual}}
                    <span data-icon><i class="icon fa-regular fa-hand-spock"></i></span>
                {{/manual}}
                {{^manual}}
                    <span data-icon><img class='icon mr-0' src='{{{moduletypeiconurl}}}' alt='{{{name}}}'></span>
                {{/manual}}
                <span data-name>{{{name}}}</span>
            </a>

            {{#hiddenfromstudents}}
                <br><div class="badge badge-warning"><i class="fa-regular fa-eye-slash"></i> Hidden from students</div>
            {{/hiddenfromstudents}}

            {{#hiddenfromreport}}
                <br><div class="badge badge-warning" data-hiddenfromreport="{{hiddenfromreport}}"><i class="fa-regular fa-eye-slash"></i> Hidden from report</div>
            {{/hiddenfromreport}}

            <span data-assessmenttype="{{assessmenttype}}" data-locked="{{locked}}" data-label="{{selectedassessmenttypelabel}}">
                {{#summative}}
                    <br><div class="badge badge-primary">{{#str}} assesstype:summative, report_feedback_tracker {{/str}}</div>
                {{/summative}}

                {{#formative}}
                    <br><div class="badge badge-secondary">{{#str}} assesstype:formative, report_feedback_tracker {{/str}}</div>
                {{/formative}}

                {{#dummy}}
                    <br><div class="badge badge-light">{{#str}} assesstype:dummy, report_feedback_tracker {{/str}}</div>
                {{/dummy}}
            </span>

            {{#duedate}}
                <br><div>Due: {{{duedate}}}</div>
            {{/duedate}}
        </div>

        <div class="col-12 col-md-7">
            {{! Student data. }}
            {{#studentdata}}
                <div class="row no-gutters">

                    <div class="col-4">
                        {{#duedate}}
                            <span class="d-md-none">Due: </span>
                            {{{duedate}}}
                        {{/duedate}}
                    </div>

                    <div class="col-4">
                        {{#feedbackduedate}}
                            <span class="d-md-none">Feedback due: </span>{{{feedbackduedate}}}
                        {{/feedbackduedate}}
                        {{#markoverdue}}
                            <br><div class="badge badge-danger">Overdue</div>
                        {{/markoverdue}}
                    </div>

                    <div class="col-4 text-right">
                        {{#mark}}
                            <span class="d-md-none">Mark: </span>
                            {{{mark}}}
                        {{/mark}}
                    </div>
                </div>
            {{/studentdata}}

            {{! Staff data. }}
            {{#staffdata}}
                <div class="row no-gutters">

                    <div class="col-4" data-feedbackduedate="{{{feedbackduedateraw}}}">
                        {{#feedbackduedate}}
                            <span class="d-md-none">Feedback due: </span><span id="js-feedbackduedate">{{{feedbackduedate}}}</span>
                        {{/feedbackduedate}}

                        {{#markoverdue}}
                            <br><div class="badge badge-danger">Overdue</div>
                        {{/markoverdue}}
                    </div>

                    <div class="col-3">
                        {{#submissions}}
                            {{submissions}} <span class="d-md-none">submitted</span>
                        {{/submissions}}

                        {{#overrides}}
                            <br><a href="{{{overridesurl}}}"  class="badge badge-warning" >{{overrides}} {{#str}}users:have_extensions, report_feedback_tracker{{/str}}</a>
                        {{/overrides}}
                    </div>

                    <div class="col-3">
                        {{#requiredfeedbacks}}
                            <a href="{{{url}}}" class="small"><strong class="h6">{{requiredfeedbacks}}</strong><br>require marking</a>
                        {{/requiredfeedbacks}}

                        <div>
                            <small>{{feedbackpercentage}}%</small>
                            <div class="progress">
                                <div class="progress-bar bg-success" role="progressbar" aria-label="Progress" aria-valuenow="{{feedbackpercentage}}" style="width: {{feedbackpercentage}}%" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-2 text-right">
                        {{#outputedit}}
                            <dev class="js-edit-tracker-data btn btn-outline-secondary" data-cmid="{{cmid}}" data-courseid="{{courseid}}" data-gradeitemid="{{gradeitemid}}" data-partid="{{partid}}" data-action="report_feedback_tracker/editmodule">
                                Edit <span class="sr-only">{{{name}}}</span>
                            </dev>
                        {{/outputedit}}
                    </div>
                </div>
            {{/staffdata}}
        </div>

    </div>
    {{#additionaldata}}
        {{> report_feedback_tracker/course/additionaldata }}
    {{/additionaldata}}

    <hr>
</div>
