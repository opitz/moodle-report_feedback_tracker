{{!
    @template report_feedback_tracker/course

    Template for a course of the Feedback tracker course report.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
    }

}}


{{! View as menu. }}

{{#canedit}}
<form class="mb-2" action="{{{ config.wwwroot }}}/report/feedback_tracker/" method="get">
    <input type="hidden" id="courseid" name="id" value="{{courseid}}">

    <div class="d-flex align-items-center">
        <label class="sr-only" for="userid">{{#str}}header:viewreport, report_feedback_tracker{{/str}}</label>
        <select class="form-control" name="userid" id="userid">
        <option value="0" {{^viewasstudent}} selected {{/viewasstudent}}>{{#str}}coursereport, report_feedback_tracker{{/str}}</option>
        {{#dropdownstudents}}
            <option value="{{id}}" {{#selected}} selected {{/selected}}>{{firstname}} {{lastname}}</option>
        {{/dropdownstudents}}
        </select>
        <input class="btn btn-primary ml-2" type="submit" value="View">
    </div>
</form>
{{/canedit}}

{{! Data header. }}
<div class="row pb-3 mb-3 text-muted border-bottom d-none d-md-flex">
    <div class="col-5">
    </div>

    <div class="col-7">
        <div class="row no-gutters">
            {{#viewasstudent}}
                <div class="col-4">{{#str}}header:duedate, report_feedback_tracker{{/str}}</div>
                <div class="col-4">{{#str}}header:feedbackdue, report_feedback_tracker{{/str}}</div>
                <div class="col-4 text-right">{{#str}}header:mark, report_feedback_tracker{{/str}}</div>
            {{/viewasstudent}}

            {{^viewasstudent}}
                <div class="col-4">{{#str}}feedback:due, report_feedback_tracker{{/str}}</div>
                <div class="col-3">{{#str}}submitted, report_feedback_tracker{{/str}}</div>
                <div class="col-3">{{#str}}header:marking, report_feedback_tracker{{/str}}</div>
            {{/viewasstudent}}
        </div>
    </div>
</div>

{{! Data. }}
{{#items}}
    {{#viewasstudent}}
        {{> report_feedback_tracker/user/mod }}
    {{/viewasstudent}}

    {{^viewasstudent}}
        {{> report_feedback_tracker/course/mod }}
    {{/viewasstudent}}
{{/items}}

{{#js}}
    require(['report_feedback_tracker/editmodule'], function(Edit) {
    Edit.init();
    });
{{/js}}
