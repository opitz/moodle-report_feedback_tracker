{{!
    @template report_feedback_tracker/course/course

    Template for a course of the Feedback tracker course report.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
    }

}}


{{! View as menu. }}
{{#canedit}}
<form class="mb-2" action="{{{ config.wwwroot }}}/report/feedback_tracker/" method="get">
    <input type="hidden" id="courseid" name="id" value="{{courseid}}">

    <div class="d-flex align-items-center">
        <label class="sr-only" for="userid">{{#str}}header:viewreport, report_feedback_tracker{{/str}}</label>
        <select class="form-control" name="userid" id="userid">
            <option value="0" {{^viewasstudent}} selected {{/viewasstudent}}>{{#str}}coursereport, report_feedback_tracker{{/str}}</option>

            {{#dropdownstudents}}
            <option value="{{id}}" {{#selected}} selected {{/selected}}>{{firstname}} {{lastname}}</option>
            {{/dropdownstudents}}
        </select>
        <input class="btn btn-primary ml-2" type="submit" value="View">
    </div>
</form>
{{/canedit}}

{{! Mods header. }}
    {{> report_feedback_tracker/mods_header }}

{{! Mods. }}
{{#items}}
    {{#viewasstudent}}
        {{> report_feedback_tracker/student/mod }}
    {{/viewasstudent}}

    {{^viewasstudent}}
        {{> report_feedback_tracker/mod }}
    {{/viewasstudent}}
{{/items}}

{{#js}}
    require(['report_feedback_tracker/editmodule'], function(edit) {
        edit.init();
    });
{{/js}}
