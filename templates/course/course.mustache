
{{! View as menu. }}

{{#canedit}}
<form class="mb-2" action="{{{ config.wwwroot }}}/report/feedback_tracker/" method="get">
    <input type="hidden" id="courseid" name="courseid" value="{{courseid}}">

    <div class="d-flex align-items-center">
        <label class="sr-only" for="userid">View report</label>
        <select class="form-control" name="userid" id="userid">
        <option value="0" {{^viewasstudent}} selected {{/viewasstudent}}>Course report</option>
        {{#students}}
            <option value="{{id}}" {{#selected}} selected {{/selected}}>{{firstname}} {{lastname}}</option>
        {{/students}}
        </select>
        <input class="btn btn-primary ml-2" type="submit" value="View">
    </div>
</form>
{{/canedit}}

{{! Data header. }}
<div class="row pb-3 mb-3 text-muted border-bottom d-none d-md-flex">
    <div class="col-5">
    </div>

    <div class="col-7">
        <div class="row no-gutters">
            {{#viewasstudent}}
                <div class="col-4">Due</div>
                <div class="col-4">Feedback due</div>
                <div class="col-4 text-right">Mark</div>
            {{/viewasstudent}}

            {{^viewasstudent}}
                <div class="col-4">Feedback due</div>
                <div class="col-3">Submitted</div>
                <div class="col-3">Marking</div>
            {{/viewasstudent}}
        </div>
    </div>
</div>

{{! Data. }}
{{#records}}
    {{> report_feedback_tracker/course/mod }}
{{/records}}