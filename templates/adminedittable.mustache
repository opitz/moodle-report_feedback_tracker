{{!
    @template report_feedback_tracker/admintable

    Template for displaying the feedback records to admins/teachers.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "assessment": "",
                "type": "",
                "summative": "",
                "duedate": "",
                "feedbackduedate": "",
                "feedbacks": "",
                "method": "",
                "responsibility": "",
                "generalfeedback": "",
                "hidden": ""
            }
        ]
    }

}}
<div class="full-width">
    <div class="table-responsive p-5">
        <table class="table">
            <thead class="small bg-light">
            <tr>
                <th scope="col" class="col_assessment align-top">{{#str}} assessment, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="align-top">{{#str}} duedate, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="align-top">{{#str}} feedbacks, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="align-top">{{#str}} method, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="align-top">{{#str}} contact, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="align-top">{{#str}} generalfeedback, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="col_summative align-top">{{#str}} summative, report_feedback_tracker {{/str}}</th>
                <th scope="col" class="col_hidden text-center align-top">{{#str}} hidden_item, report_feedback_tracker {{/str}}</th>
            </tr>
            </thead>
            <tbody>
            {{#records}}
                <tr>
                    <td class="col_assessment" data-filter="{{module}}" data-filter-assessment="{{module}}">
                        <div class="small w-100">
                            {{{course}}}
                        </div>
                        <div class="w-100">
                            {{{type}}} {{{assessment}}}
                        </div>
                    </td>
                    <td class="col_duedate text-nowrap">{{duedate}}</td>
                    <td class="col_feedbacks">
                        <div class="small w-100 text-nowrap">
                            {{{feedbackduedate}}}
                        </div>
                        <div class="w-100">
                            {{{feedbacks}}}
                        </div>
                    </td>
                    <td class="col_method">{{{method}}}</td>
                    <td class="col_responsibility">{{{responsibility}}}</td>
                    <td class="col_generalfeedback">{{{generalfeedback}}}</td>
                    <td class="col_summative text-center">{{{summative}}}</td>
                    <td class="col_hidden text-center">{{{hidden}}}</td>
                </tr>
            {{/records}}
            </tbody>
        </table>
    </div>
</div>

{{#js}}
    require(['report_feedback_tracker/adminedit'], function(Edit) {
    Edit.init();
    });
{{/js}}
