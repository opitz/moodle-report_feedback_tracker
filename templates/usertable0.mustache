{{!
    @template report_feedback_tracker/usertable

    Template for displaying the feedback records to users/students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}
<div class="full-width">
    <div class="table-responsive p-5">
        <table class="table" id="feedback_table">
            <thead class="small bg-light">
            <tr class="feedback_table_header">
                <th scope="col" class="align-top" style="min-width: 300px; width: 300px;">{{#str}} course, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" style="min-width: 300px; width: 300px;">{{#str}} assessment, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} type, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} duedate, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} submissiondate, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} feedbackduedate, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} feedback, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} method, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top">{{#str}} generalfeedback, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
            </tr>
            <tr id="feedback_table_filterrow" class="bg-light">
                <td>
                    <label for="filtercourse" class="sr-only">{{#str}}filter:course, report_feedback_tracker{{/str}}</label>
                    <select id="filtercourse" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:by, report_feedback_tracker{{/str}}</option>
                        {{#courseoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/courseoptions}}
                    </select>
                </td>
                <td>
                    <label for="filtertype" class="sr-only">{{#str}}filter:type, report_feedback_tracker{{/str}}</label>
                    <select id="filtertype" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:by, report_feedback_tracker{{/str}}</option>
                        {{#typeoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/typeoptions}}
                    </select>
                </td>
                <td>
                    <label for="filtersummative" class="sr-only">{{#str}}filter:summative, report_feedback_tracker{{/str}}</label>
                    <select id="filtersummative" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:by, report_feedback_tracker{{/str}}</option>
                        {{#summativeoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/summativeoptions}}
                    </select>
                </td>
                <td id="filterduedate">
                </td>
                <td id="filtersubmissiondate">
                </td>
                <td id="filterfeedbackduedate">
                </td>
                <td>
                    <label for="filterfeedback" class="sr-only">{{#str}}filter:feedback, report_feedback_tracker{{/str}}</label>
                    <select id="filterfeedback" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:by, report_feedback_tracker{{/str}}</option>
                        {{#feedbackoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/feedbackoptions}}
                    </select>
                </td>
                <td id="filtermethod">
                </td>
                <td id="filtergeneralfeedback">
                </td>
            </tr>
            </thead>
            <tbody>
            {{#records}}
                <tr>
                    <td class="col_course" data-filter="{{courseid}}">{{{course}}}</td>
                    <td class="col_assessment" data-filter="{{module}}">{{{type}}} {{{assessment}}}</td>
                    <td class="col_summative small" data-filter="{{summative}}">{{{summative}}}</td>
                    <td class="col_duedate text-nowrap small">{{duedate}}</td>
                    <td class="col_submissiondate text-nowrap small">{{submissiondate}}</td>
                    <td class="col_feedbackduedate text-nowrap small">{{{feedbackduedate}}}</td>
                    <td class="col_feedback" data-filter="{{feedbackstatus}}">{{{feedback}}}</td>
                    <td class="col_method" data-filter="{{method}}">{{{method}}}</td>
                    <td class="col_generalfeedback">{{{generalfeedback}}}</td>
                </tr>
            {{/records}}
            </tbody>
        </table>
    </div>
</div>

{{#js}}
    require(['report_feedback_tracker/tablefilters'], function(tablefilters) {
    tablefilters.init();
    });
    require(['report_feedback_tracker/tablesort'], function(tablesort) {
    tablesort.init();
    });
{{/js}}
