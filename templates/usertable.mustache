{{!
    @template report_feedback_tracker/usertable

    Template for displaying the feedback records to users/students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}
<div class="full-width">
    <div class="table-responsive p-5">
        <table class="table" id="feedback_table">
            <thead class="small bg-light">
            <tr class="feedback_table_header">
                <th scope="col" class="align-top" style="min-width: 300px; width: 300px;" data-column="col_assessment">{{#str}} assessment, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" data-column="col_type">{{#str}} type, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" data-column="col_submissiondate" data-type="numeric">{{#str}} duesubmissiondate, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" data-column="col_feedbackduedate" data-type="numeric">{{#str}} feedbackduedate, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" data-column="col_method">{{#str}} method, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
                <th scope="col" class="align-top" data-column="col_generalfeedback">{{#str}} generalfeedback, report_feedback_tracker {{/str}} <span class="indicator"></span></th>
            </tr>
            <tr id="feedback_table_filterrow" class="bg-light">
                <td class="d-flex align-items-center">
                    <label for="filteracademicyear" class="sr-only">{{#str}}filter:course, report_feedback_tracker{{/str}}</label>
                    <select id="filteracademicyear" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:academicyear, report_feedback_tracker{{/str}}</option>
                        {{#academicyearoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/academicyearoptions}}
                    </select>
                    <label for="filtercourse" class="sr-only">{{#str}}filter:course, report_feedback_tracker{{/str}}</label>
                    <select id="filtercourse" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:course, report_feedback_tracker{{/str}}</option>
                        {{#courseoptions}}
                            <option value="{{key}}" data-filter-academicyear="{{academicyear}}">{{value}}</option>
                        {{/courseoptions}}
                    </select>
                    <label for="filtertype" class="sr-only">{{#str}}filter:type, report_feedback_tracker{{/str}}</label>
                    <select id="filtertype" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:type, report_feedback_tracker{{/str}}</option>
                        {{#typeoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/typeoptions}}
                    </select>
                </td>
                <td>
                    <label for="filtersummative" class="sr-only">{{#str}}filter:summative, report_feedback_tracker{{/str}}</label>
                    <select id="filtersummative" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:summative, report_feedback_tracker{{/str}}</option>
                        {{#summativeoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/summativeoptions}}
                    </select>
                </td>
                <td>
                </td>
                <td>
                    <label for="filterfeedback" class="sr-only">{{#str}}filter:feedback, report_feedback_tracker{{/str}}</label>
                    <select id="filterfeedback" class="custom-select custom-select-sm w-100">
                        <option value="">{{#str}}filter:feedback, report_feedback_tracker{{/str}}</option>
                        {{#feedbackoptions}}
                            <option value="{{key}}">{{value}}</option>
                        {{/feedbackoptions}}
                    </select>
                </td>
                <td id="filtermethod">
                </td>
                <td id="filtergeneralfeedback">
                </td>
            </tr>
            </thead>
            <tbody>
            {{#records}}
                <tr>
                    <td class="col_course col_assessment col_academicyear" data-filter="{{courseid}}" data-filter-academicyear="{{academicyear}}" data-filter-assessment="{{module}}">
                        <div class="small w-100 text-nowrap">
                            {{{course}}}{{#academicyear}} ({{academicyear}}){{/academicyear}}
                        </div>
                        <div class="w-100 sort-this" data-sort="assessment">
                            {{{type}}} {{{assessment}}}
                        </div>
                    </td>
                    <td class="col_summative small sort-this" data-filter="{{summative}}">{{{summative}}}</td>
                    <td class="col_submissiondate text-nowrap">
                        <div class="sort-this hidden">{{{duedateraw}}}</div>
                        <div class="text-nowrap small w-100 mb-1">
                            {{duedate}}
                        </div>
                        <div class="w-100">
                            {{{submissionstatus}}}
                        </div>
                    </td>
                    <td class="col_feedback" data-filter="{{feedbackstatus}}">
                        <div class="sort-this hidden">{{{feedbackduedateraw}}}</div>
                        <div class="small w-100">
                            {{{feedbackduedate}}}
                        </div>
                        <div class="w-100">
                            {{{feedbackbadge}}}
                        </div>
                    </td>
                    <td class="col_method" data-filter="{{method}}">
                        <div class="sort-this">{{{method}}}</div>
                    </td>
                    <td class="col_generalfeedback sort-this">
                        <div class="sort-this">{{{generalfeedback}}}</div>
                    </td>
                </tr>
            {{/records}}
            </tbody>
        </table>
    </div>
</div>

{{#js}}
    require(['report_feedback_tracker/tablefilters'], function(tablefilters) {
        tablefilters.init();
    });
    require(['report_feedback_tracker/tablesort'], function(tablesort) {
        tablesort.init();
    });
{{/js}}