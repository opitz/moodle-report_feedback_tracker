{{!
    @template report_feedback_tracker/usertable

    Template for displaying the feedback records to users/students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}
<table class="table" id="user_feedback_table">
    <thead>
        <tr>
            <th scope="col">{{#str}} course, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} assessment, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} type, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} duedate, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} submissiondate, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} feedbackduedate, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} feedback, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} method, report_feedback_tracker {{/str}}</th>
            <th scope="col">{{#str}} generalfeedback, report_feedback_tracker {{/str}}</th>
        </tr>
        <tr id="filterRow">
            <th>
                <select id="filtercourse">
                    <option value="">All</option>
                    {{#courseoptions}}
                        <option value="{{key}}">{{value}}</option>
                    {{/courseoptions}}
                </select>
            </th>
            <th>
                <select id="filtertype">
                    <option value="">All</option>
                    {{#typeoptions}}
                        <option value="{{key}}">{{value}}</option>
                    {{/typeoptions}}
                </select>
            </th>
            <th>
                <select id="filtersummative">
                    <option value="">All</option>
                    {{#summativeoptions}}
                        <option value="{{key}}">{{value}}</option>
                    {{/summativeoptions}}
                </select>
            </th>
            <th id="filterduedate">
            </th>
            <th id="filtersubmissiondate">
            </th>
            <th id="filterfeedbackduedate">
            </th>
            <th>
                <select id="filterfeedback">
                    <option value="">All</option>
                    {{#feedbackoptions}}
                        <option value="{{key}}">{{value}}</option>
                    {{/feedbackoptions}}
                </select>
            </th>
            <th>
                <select id="filtermethod">
                    <option value="">All</option>
                    {{#methodoptions}}
                        <option value="{{key}}">{{value}}</option>
                    {{/methodoptions}}
                </select>
            </th>
            <th id="filtergeneralfeedback">
            </th>
        </tr>
    </thead>
    <tbody>
        {{#records}}
            <tr>
                <td class="col_course" data-filter="{{courseid}}">{{{course}}}</td>
                <td class="col_assessment" data-filter="{{module}}">{{{type}}} {{{assessment}}}</td>
                <td class="col_summative" data-filter="{{summative}}">{{{summative}}}</td>
                <td class="col_duedate">{{duedate}}</td>
                <td class="col_submissiondate">{{submissiondate}}</td>
                <td class="col_feedbackduedate">{{{feedbackduedate}}}</td>
                <td class="col_feedback" data-filter="{{feedbackstatus}}">{{{feedback}}}</td>
                <td class="col_method" data-filter="{{method}}">{{{method}}}</td>
                <td class="col_generalfeedback">{{{generalfeedback}}}</td>
            </tr>
        {{/records}}
    </tbody>
</table>

{{#js}}
    require(['report_feedback_tracker/studentfilter'], function(studentfilter) {
    studentfilter.init();
    });
{{/js}}
