{{!
    @template report_feedback_tracker/student/mod

    Template for displaying the feedback for a course module to students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "moduletypeiconurl": "#",
        "viewasstudent": true,
        "studentdata": true,
        "items": [],
        "courses": [
            {
                "url": {},
                "image": false,
                "fullname": "Group Testing Course",
                "items": [
                    {
                        "cmid": "120",
                        "gradeitemid": "18",
                        "modname": "assign",
                        "name": "Group Assessment - groups required",
                        "url": "http:\/\/localhost\/mod\/assign\/view.php?id=120",
                        "moduletypeiconurl": "#",
                        "partid": null,
                        "formative": false,
                        "summative": true,
                        "dummy": false,
                        "duedate": "21 Mar 2025",
                        "feedbackduedateraw": 1745366399,
                        "feedbackduedate": "23 Apr 2025",
                        "markoverdue": false,
                        "submissiondate": "14 Mar 2025",
                        "submissionstatus": {
                            "success": "success"
                        },
                        "grade": "80\/100",
                        "notset": false,
                        "hiddenfromreport": false,
                        "feedbackstatus": {
                            "released": "released"
                        }
                    }
                ]
            }
        ],
        "userfirstname": "Peppa",
        "userlastname": "Pig",
        "student": "peppapig",
        "hasyears": true,
        "academicyearoptions": [
            {
                "value": "2024-25"
            }
        ],
        "canedit": false
    }
}}

<div class="row">

    <!-- Mod name. -->
    <div class="col-12 col-md-5 mb-3 mb-md-0">
        {{^moduletypeiconurl}}{{! Manual grade item }}
            <i class="fa fa-hand-paper-o" style="color: grey;"></i>
            {{{name}}}
        {{/moduletypeiconurl}}
        {{#moduletypeiconurl}}
            <a href="{{{url}}}">
                <img class='icon mr-0' src='{{{moduletypeiconurl}}}' alt=''>
                {{{name}}}
            </a>
        {{/moduletypeiconurl}}
    </div>

    <!-- Mod metadata. -->
    <div class="col">
        <div class="row">
            <div class="col-4">
                <small>
                    <span class="d-md-none">{{#str}} due, report_feedback_tracker {{/str}}:</span>
                    <span class="text-nowrap">{{duedate}}</span>
                </small>
                <br>
                {{#submissionstatus}}
                    {{#success}}
                        <span class="badge badge-success">{{#str}} submission:success, report_feedback_tracker {{/str}}</span>
                    {{/success}}
                    {{#late}}
                        <span class="badge badge-warning">{{#str}} submission:late, report_feedback_tracker {{/str}}</span>
                    {{/late}}
                    {{#overdue}}
                        <span class="badge badge-danger">{{#str}} submission:overdue, report_feedback_tracker {{/str}}</span>
                    {{/overdue}}
                {{/submissionstatus}}
            </div>

            <!-- Feedback data. -->
            <div class="col-4">
                <small>
                    <span class="d-md-none">{{#str}} feedback:due, report_feedback_tracker {{/str}}:</span>
                    <span class="text-nowrap">{{{feedbackduedate}}}</span>
                </small>
                {{#feedbackstatus}}
                    <br>
                    {{#released}}
                        <span class="badge badge-success">{{#str}} feedback:released, report_feedback_tracker {{/str}}</span>
                    {{/released}}
                    {{#late}}
                        <span class="badge badge-warning">{{#str}} feedback:late, report_feedback_tracker {{/str}}</span>
                    {{/late}}
                    {{#overdue}}
                        <span class="badge badge-danger">{{#str}} feedback:overdue, report_feedback_tracker {{/str}}</span>
                    {{/overdue}}
                {{/feedbackstatus}}
            </div>

            <!-- Mark data. -->
            <div class="col-4">
                <small class="d-md-none">{{#str}}header:mark, report_feedback_tracker{{/str}}:</small>
                {{#grade}} <strong> {{.}} </strong> {{/grade}}
                {{^grade}} <small> {{#str}}feedback:notreleased, report_feedback_tracker{{/str}} </small> {{/grade}}
                <br>
                {{#summative}}
                    <span class="badge badge-primary">
                        {{#str}}summative, report_feedback_tracker{{/str}}
                    </span>
                {{/summative}}

                {{#formative}}
                    <span class="badge badge-secondary">
                        {{#str}}formative, report_feedback_tracker{{/str}}
                    </span>
                {{/formative}}
            </div>
        </div>
    </div>
</div>

{{#additionaldata}}
    {{> report_feedback_tracker/additionaldata }}
{{/additionaldata}}
<hr>
