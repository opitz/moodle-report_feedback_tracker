{{!
    @template report_feedback_tracker/ayselector

    Sub-template for displaying a selector for academic years.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
    }

}}
<div>
    {{#str}} academicyear, report_feedback_tracker {{/str}}
    {{#academicyearoptions}}:
        {{^key}}
            <strong>{{value}}</strong>
        {{/key}}
        {{#key}}
            <a href="{{{ config.wwwroot }}}/report/feedback_tracker/student.php?year={{key}}">{{value}}</a>
        {{/key}}
    {{/academicyearoptions}}
</div>
