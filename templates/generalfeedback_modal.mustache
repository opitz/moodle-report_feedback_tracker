{{!
    @template report_feedback_tracker/usertable

    Template for displaying a modal dialog to edit general feedback.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "title": "A title",
        "generalfeedbacklabel": "General Feedback:",
        "generalfeedback": "This is good.",
        "gfurllabel": "NASA",
        "gfurl": "www.nasa.gov"
    }

}}
<div class="modal-header">
    <h4>{{title}}</h4>
</div>
<div class="modal-body">
    <form id="modalForm">
        <div class="form-group">
            <label for="generalfeedback">{{generalfeedbacklabel}}</label>
            <textarea class="form-control" id="generalfeedback" name="generalfeedback" rows= "5">{{{generalfeedback}}}</textarea>
        </div>
        <div class="form-group">
            <label for="gfurl">{{gfurllabel}}</label>
            <input type="text" class="form-control" id="gfurl" name="gfurl" value="{{{gfurl}}}">
        </div>
    </form>
</div>
