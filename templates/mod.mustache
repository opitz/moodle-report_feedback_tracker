{{!
    @template report_feedback_tracker/usertable

    Template for displaying the feedback records to users/students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}

<div class="row">
    <!-- Mod name. -->
    <div class="col-12 col-md-5 mb-3 mb-md-0">
        {{{type}}} {{{assessment}}}
    </div>
    <!-- Mod metadata. -->
    <div class="col">
        <div class="row">
            <div class="col-4">
                <small>
                    <span class="text-muted">{{#str}}duedate, report_feedback_tracker{{/str}}:</span> {{duedate}}
                </small>
                <br>
                {{#submissionstatus}}
                    {{{submissionstatus}}}
                {{/submissionstatus}}
            </div>

            <!-- Feedback data. -->
            <div class="col-4">
                <small>
                    <span class="text-muted">{{#str}}feedback:due, report_feedback_tracker{{/str}}:</span> {{{feedbackduedate}}}
                </small>
                {{#feedbackbadge}}
                    <br>
                    {{{feedbackbadge}}}
                {{/feedbackbadge}}
                {{#method}}
                    <br>
                    <span class="text-nowrap small">{{#str}}method, report_feedback_tracker{{/str}}: {{{method}}}</span>
                {{/method}}
            </div>

            <!-- Marks data. -->
            <div class="col-4 text-right">
                {{#grade}}
                    <small class="text-muted">{{#str}}marks, report_feedback_tracker{{/str}}:</small> <strong>{{grade}}</strong>
                {{/grade}}
                <br>
                {{#summative}}
                    <span data-toggle="tooltip"
                          title="{{#str}}summative:tooltip, report_feedback_tracker{{/str}}"
                          class="badge badge-dark">
                        {{summative}}
                    </span>
                {{/summative}}

                {{#formative}}
                    <span class="badge badge-secondary">{{#str}}formative, report_feedback_tracker{{/str}}</span>
                {{/formative}}
            </div>

        </div>
    </div>

    <!-- Free text fields. -->

    {{#additionaldata}}
        <div class="col p-2 bg-light small">
            {{#content}}
                <span class="text-muted">{{#str}}contact, report_feedback_tracker{{/str}}:</span>
                Kyle Minogue
                <br>
            {{/content}}

            {{#method}}
                <span class="text-muted">{{#str}}method, report_feedback_tracker{{/str}}:</span>
                {{.}}
                <br>
            {{/method}}

            {{#additionalinformation}}
                <span class="text-muted">{{#str}}additionalinformation, report_feedback_tracker{{/str}}:</span>
                {{.}}
                <br>
            {{/additionalinformation}}

        </div>
    {{/additionaldata}}
</div>
<hr>
