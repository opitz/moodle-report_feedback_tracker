{{!
    @template report_feedback_tracker/usertable

    Template for displaying the feedback records to users/students.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "records": [
            {
                "course": "",
                "assessment": "",
                "type": "",
                "type": "",
                "duedate": "",
                "submissiondate": "",
                "feedbackduedate": "",
                "feedback": ""
            }
        ]
    }

}}

<div class="row">

    <!-- Mod name. -->
    <div class="col-12 col-md-5 mb-3 mb-md-0">
        {{{type}}} {{{assessment}}}
    </div>

    <!-- Mod metadata. -->
    <div class="col">
        <div class="row">
            <div class="col-4">
                <small>
                    <span class="text-muted">{{#str}}duedate, report_feedback_tracker{{/str}}:</span>
                    <span class="text-nowrap">{{duedate}}</span>
                </small>
                <br>
                {{#submissionstatus}}
                    {{{submissionstatus}}}
                {{/submissionstatus}}
            </div>

            <!-- Feedback data. -->
            <div class="col-4">
                <small>
                    <span class="text-muted">{{#str}}feedback:due, report_feedback_tracker{{/str}}:</span>
                    <span class="text-nowrap">{{{feedbackduedate}}}</span>
                </small>
                {{#feedbackbadge}}
                <br>
                {{{feedbackbadge}}}
                {{/feedbackbadge}}
            </div>

            <!-- Mark data. -->
            <div class="col-4 text-right">
                <small class="text-muted">{{#str}}mark, report_feedback_tracker{{/str}}:</small>
                {{#grade}} <strong> {{.}} </strong> {{/grade}}
                {{^grade}} <small> {{#str}}feedback:notreleased, report_feedback_tracker{{/str}} </small> {{/grade}}
                <br>
                {{#summative}}
                    <span data-toggle="tooltip"
                          title="{{#str}}summative:tooltip, report_feedback_tracker{{/str}}"
                          class="badge badge-dark">
                        {{summative}}
                    </span>
                {{/summative}}

                {{#formative}}
                    <span class="badge badge-secondary">{{#str}}formative, report_feedback_tracker{{/str}}</span>
                {{/formative}}
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Free text fields. -->

    {{#additionaldata}}
        <div class="col mb-2 bg-light small">
            {{#contact}}
                <span class="text-muted">{{#str}}contact, report_feedback_tracker{{/str}}:</span>
                {{.}}
                <br>
            {{/contact}}

            {{#method}}
                <span class="text-muted">{{#str}}method, report_feedback_tracker{{/str}}:</span>
                {{.}}
                <br>
            {{/method}}

            {{#generalfeedback}}
                <span class="text-muted">{{#str}}additionalinformation, report_feedback_tracker{{/str}}:</span>
                {{{.}}}
                <br>
            {{/generalfeedback}}

        </div>
    {{/additionaldata}}
</div>
<hr>
