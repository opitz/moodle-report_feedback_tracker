{{!
    @template report_feedback_tracker/duedatereason_modal

    Template for displaying a modal dialog to enter a reason for a manual feedback due date.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "title": "Please give a reason for a manual feedback due date:",
        "duedatereason": "Unforseen personal events."
    }

}}
<div class="modal-header">
    <h4>{{title}}</h4>
</div>
<div class="modal-body">
    <form id="modalForm">
        <div class="d-flex flex-start">
            <i class="fa fa-info-circle text-danger mr-1" title="{{#str}} field_required, report_feedback_tracker {{/str}}"></i>
            <textarea class="form-control" id="duedatereason" name="duedatereason" rows= "5">{{{reason}}}</textarea>
        </div>
        <br>
        <div id="reason-error" class="align-items-center d-none text-danger">
            <i class="fa fa-info-circle text-danger mr-1" title="{{#str}} field_required, report_feedback_tracker {{/str}}"></i>
            <span>{{#str}} field_required, report_feedback_tracker {{/str}}</span>
        </div>
    </form>
</div>
